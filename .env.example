# Somnia Environment Configuration
# Copy to .env and fill in your values

# ── Core credentials ────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=somnia
POSTGRES_PASSWORD=changeme

# 1Password Service Account (optional, for secrets management)
OP_SERVICE_ACCOUNT_TOKEN=

# Anthropic API Key (for Quies dream cycles)
ANTHROPIC_API_KEY=

# ── Data paths (override for your environment) ─────────────────────────────

# SOMNIA_DATA_ROOT=/volume1/docker/somnia
# SOMNIA_CONFIG_DIR=./config
# SOMNIA_DOMAINS_DIR=./domains
# SOMNIA_WORKSPACES_DIR=./workspaces
# SOMNIA_REPOS_DIR=./
# SOMNIA_OUTPUTS_DIR=./outputs
# SOMNIA_DOCUMENTS_DIR=./documents

# ── Quies daemon tuning ────────────────────────────────────────────────────
# Override any config.yaml value via QUIES_{SECTION}__{KEY} env vars.
# Double-underscore separates section from key. Values are coerced to
# match the default's type (int, float, bool, str).
#
# Full list of tunable parameters is in quies/daemon/settings.py DEFAULTS.
# Examples:

# Scheduler timing
# QUIES_SCHEDULER__GLOBAL_COOLDOWN_MINUTES=240      # 4hr between any dream
# QUIES_SCHEDULER__CHECK_INTERVAL_MINUTES=15         # poll frequency
# QUIES_SCHEDULER__RUMINATION_COOLDOWN_MINUTES=360   # 6hr between rumination
# QUIES_SCHEDULER__SOLO_WORK_COOLDOWN_MINUTES=360    # 6hr between solo-work
# QUIES_SCHEDULER__ARCHAEOLOGY_COOLDOWN_MINUTES=720  # 12hr between archaeology
# QUIES_SCHEDULER__ENABLED=true                      # kill switch for scheduler

# Budget controls
# QUIES_BUDGET__MAX_COST_PER_DAY=2.00        # daily hard cap (USD)
# QUIES_BUDGET__MAX_COST_DREAM=0.30          # per-session: processing
# QUIES_BUDGET__MAX_COST_RUMINATION=0.30     # per-session: rumination
# QUIES_BUDGET__MAX_COST_SOLO_WORK=1.00      # per-session: solo-work
# QUIES_BUDGET__MAX_COST_ARCHAEOLOGY=0.30    # per-session: archaeology

# API
# QUIES_API__MODEL=claude-sonnet-4-20250514
# QUIES_API__MAX_TOKENS=8192
